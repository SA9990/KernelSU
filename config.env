# Kernel Build Configuration File

# General Configuration
export CONFIG_ENV=config.env
export ARCH=arm64
export KERNEL_SOURCE=https://github.com/BlissRoms-Devices/android_kernel_asus_sm8250
export KERNEL_SOURCE_BRANCH=universe
export KERNEL_CONFIG=vendor/obiwan_defconfig
export KERNEL_IMAGE_NAME=Image
export ADD_LOCALVERSION_TO_FILENAME=false
export EXTRA_CMDS="LD=ld.lld"

# Clang Configuration
## Use Custom Clang
export USE_CUSTOM_CLANG=true
export CUSTOM_CLANG_SOURCE=https://github.com/BlissRoms/platform_prebuilts_clang_host_linux-x86_clang-r416183b1
export CUSTOM_CLANG_BRANCH=universe
export CUSTOM_CMDS="CLANG_TRIPLE=aarch64-linux-gnu-"

## AOSP Clang (Only used if USE_CUSTOM_CLANG is false)
export CLANG_BRANCH=master-kernel-build-2021
export CLANG_VERSION=r487747c

# GCC Compiler Configuration
## ARM64 GCC Compiler
export ENABLE_GCC_ARM64=true
export USE_CUSTOM_GCC_64=false
export CUSTOM_GCC_64_SOURCE=
export CUSTOM_GCC_64_BRANCH=
export CUSTOM_GCC_64_BIN=aarch64-linux-android-

## ARM32 GCC Compiler
export ENABLE_GCC_ARM32=true
export USE_CUSTOM_GCC_32=false
export CUSTOM_GCC_32_SOURCE=
export CUSTOM_GCC_32_BRANCH=
export CUSTOM_GCC_32_BIN=arm-linux-androideabi-

# KernelSU Configuration
export ENABLE_KERNELSU=false
export KERNELSU_TAG=v0.9.5
export KSU_EXPECTED_SIZE=
export KSU_EXPECTED_HASH=

# Kernel Build Options
export DISABLE_LTO=false                # Disable Link-Time Optimization
export DISABLE_CC_WERROR=true           # Disable -Werror for warnings
export ADD_KPROBES_CONFIG=false         # Add kprobes support
export ADD_OVERLAYFS_CONFIG=false       # Add OverlayFS support
export APPLY_KSU_PATCH=false            # Apply KernelSU patch
export REMOVE_UNUSED_PACKAGES=true      # Remove unused packages to optimize the build

# AnyKernel3 Configuration
export USE_CUSTOM_ANYKERNEL3=false
export CUSTOM_ANYKERNEL3_SOURCE=
export CUSTOM_ANYKERNEL3_BRANCH=

# Ccache Configuration
export ENABLE_CCACHE=true

# DTBO Image Configuration
export NEED_DTBO=false

# Boot Image Configuration
export BUILD_BOOT_IMG=true
export SOURCE_BOOT_IMAGE=https://sourceforge.net/projects/payload/files/Boot/boot.img
