# Kernel configuration
CONFIG_ENV=config.env
KERNEL_SOURCE=https://github.com/BlissRoms-Devices/android_kernel_asus_sm8250
KERNEL_SOURCE_BRANCH=universe-old
KERNEL_CONFIG=vendor/obiwan_defconfig
KERNEL_IMAGE_NAME=Image
ARCH=arm64
ADD_LOCALVERSION_TO_FILENAME=false
EXTRA_CMDS:LD=ld.lld

# Clang configuration
USE_CUSTOM_CLANG=true
CUSTOM_CLANG_SOURCE=https://github.com/BlissRoms/platform_prebuilts_clang_host_linux-x86_clang-r416183b1
CUSTOM_CLANG_BRANCH=universe
CUSTOM_CMDS:CLANG_TRIPLE=aarch64-linux-gnu-

# GCC configuration
ENABLE_GCC_ARM64=true
ENABLE_GCC_ARM32=true
USE_CUSTOM_GCC_64=false
CUSTOM_GCC_64_SOURCE=
CUSTOM_GCC_64_BRANCH=
CUSTOM_GCC_64_BIN=aarch64-linux-android-
USE_CUSTOM_GCC_32=false
CUSTOM_GCC_32_SOURCE=
CUSTOM_GCC_32_BRANCH=
CUSTOM_GCC_32_BIN=arm-linux-androideabi-

# KernelSU configuration
ENABLE_KERNELSU=false
KERNELSU_TAG=v0.9.5
KSU_EXPECTED_SIZE=
KSU_EXPECTED_HASH=

# Build configuration
DISABLE_LTO=false
DISABLE_CC_WERROR=true
ADD_KPROBES_CONFIG=false
ADD_OVERLAYFS_CONFIG=false
APPLY_KSU_PATCH=false
REMOVE_UNUSED_PACKAGES=true

# AnyKernel3 configuration
USE_CUSTOM_ANYKERNEL3=false
CUSTOM_ANYKERNEL3_SOURCE=
CUSTOM_ANYKERNEL3_BRANCH=

# Ccache configuration
ENABLE_CCACHE=true

# DTBO image configuration
NEED_DTBO=false

# Boot image configuration
BUILD_BOOT_IMG=false
SOURCE_BOOT_IMAGE=https://sourceforge.net/projects/payload/files/Boot/boot.img

# Device Tree Source location
DTS_LOCATION=arch/arm64/boot/dts/vendor
